function buildRecipeHTML(r) {
  const hasTm = r.tm && r.tm.length;
  const hasGarnek = r.garnek && r.garnek.length;
  const tmLabel = hasTm ? (r.tm === r.garnek ? 'Instrukcja' : 'Thermomix') : '';
  const garnekLabel = hasGarnek ? (r.chapter === 'napoje' && r.num >= 16 ? 'Ręcznie' : 'Garnek') : '';

  const tags = r.tags.map(t => {
    const isTm = t.toLowerCase().includes('thermomix');
    return `<span class="tag${isTm ? ' tm' : ''}">${t}</span>`;
  }).join('');

  const ingredients = r.ingredients.map(i => `<li>${i}</li>`).join('');
  const tmSteps = hasTm ? r.tm.map(s => `<li>${s}</li>`).join('') : '';
  const garnekSteps = hasGarnek ? r.garnek.map(s => `<li>${s}</li>`).join('') : '';
  const props = r.props ? r.props.map(p => `<li>${p}</li>`).join('') : '';

  const methodTabsHTML = (hasTm && hasGarnek) ? `
    <div class="method-tabs">
      <button class="method-tab active" onclick="switchTab(this, 'tm-${r.num}')">🌀 ${tmLabel}</button>
      <button class="method-tab" onclick="switchTab(this, 'garnek-${r.num}')">🥘 ${garnekLabel}</button>
    </div>` : '';

  const tmHTML = hasTm ? `
    <div id="tm-${r.num}" class="recipe-section method-pane">
      <p class="section-label">Kroki</p>
      <ol class="step-list">${tmSteps}</ol>
    </div>` : '';

  const garnekHTML = hasGarnek ? `
    <div id="garnek-${r.num}" class="recipe-section method-pane" style="${hasTm ? 'display:none' : ''}">
      <p class="section-label">Kroki</p>
      <ol class="step-list">${garnekSteps}</ol>
    </div>` : '';

  const tipHTML = r.tip ? `<div class="recipe-section"><p class="section-label">Wskazówka</p><div class="tip-box">${r.tip}</div></div>` : '';
  const warnHTML = r.warning ? `<div class="recipe-section"><p class="section-label">Ważne</p><div class="warning-box">${r.warning}</div></div>` : '';
  const propsHTML = props ? `<div class="recipe-section"><p class="section-label">Właściwości zdrowotne</p><ul class="prop-list">${props}</ul></div>` : '';

  return `
  <div class="recipe-card" data-chapter="${r.chapter}" data-search="${r.title.toLowerCase()} ${(r.subtitle||'').toLowerCase()} ${r.tags.join(' ').toLowerCase()}">
    <div class="recipe-card-header" onclick="toggleCard(this)">
      <div>
        <span class="recipe-num">Przepis ${r.num}</span>
        <div class="recipe-title">${r.title}</div>
        <div class="recipe-subtitle">${r.subtitle || ''}</div>
        <div class="recipe-tags">${tags}</div>
      </div>
      <span class="chevron">▼</span>
    </div>
    <div class="recipe-body">
      <div class="recipe-section">
        <p class="section-label">Składniki</p>
        <ul class="ingredient-list">${ingredients}</ul>
      </div>
      ${methodTabsHTML}
      ${tmHTML}
      ${garnekHTML}
      ${tipHTML}
      ${warnHTML}
      ${propsHTML}
    </div>
  </div>`;
}

function renderRecipes() {
  document.getElementById('recipe-list').innerHTML = RECIPES.map(buildRecipeHTML).join('');
}

function toggleCard(header) {
  const card = header.parentElement;
  card.classList.toggle('open');
}

function switchTab(btn, targetId) {
  const body = btn.closest('.recipe-body');
  body.querySelectorAll('.method-tab').forEach(t => t.classList.remove('active'));
  body.querySelectorAll('.method-pane').forEach(p => p.style.display = 'none');
  btn.classList.add('active');
  document.getElementById(targetId).style.display = 'block';
}

function filterChapter(chapter, btn) {
  document.querySelectorAll('.chapter-nav button').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.recipe-card').forEach(card => {
    card.classList.toggle('hidden', chapter !== 'all' && card.dataset.chapter !== chapter);
  });
  document.getElementById('search-input').value = '';
}

function filterRecipes() {
  const q = document.getElementById('search-input').value.toLowerCase();
  document.querySelectorAll('.recipe-card').forEach(card => {
    card.classList.toggle('hidden', q.length > 1 && !card.dataset.search.includes(q));
  });
  if (q.length > 1) {
    document.querySelectorAll('.chapter-nav button').forEach(b => b.classList.remove('active'));
  }
}

function togglePhase(header) {
  const card = header.parentElement;
  card.classList.toggle('open');
}

function showPage(name, btn) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.bottom-nav button').forEach(b => b.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  btn.classList.add('active');
}

function toggleCheck(el) {
  el.classList.toggle('checked');
  el.textContent = el.classList.contains('checked') ? '✓' : '';
}

renderRecipes();
</script>
