<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kuchnia Ajurwedyjska & TMC</title>
<style>
  :root {
    --gold: #c8963e;
    --gold-light: #f5e6c8;
    --brown: #6b4226;
    --cream: #fdf6ec;
    --green: #5a7a52;
    --text: #2d1f0e;
    --muted: #8a6a4a;
    --card: #fff9f0;
    --border: #e8d5b0;
    --shadow: 0 2px 12px rgba(107,66,38,0.10);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Georgia', serif; background: var(--cream); color: var(--text); font-size: 16px; line-height: 1.6; }

  /* HEADER */
  header { background: linear-gradient(135deg, var(--brown) 0%, #3d1f0a 100%); color: white; padding: 20px 16px 14px; text-align: center; position: sticky; top: 0; z-index: 100; box-shadow: 0 2px 8px rgba(0,0,0,0.3); }
  header h1 { font-size: 1.25rem; letter-spacing: 0.03em; color: var(--gold-light); margin-bottom: 2px; }
  header p { font-size: 0.78rem; color: #d4b896; font-style: italic; }

  /* SEARCH */
  .search-bar { padding: 12px 16px; background: white; border-bottom: 1px solid var(--border); }
  .search-bar input { width: 100%; padding: 10px 14px; border: 1.5px solid var(--border); border-radius: 24px; font-size: 1rem; font-family: inherit; background: var(--cream); color: var(--text); outline: none; }
  .search-bar input:focus { border-color: var(--gold); }

  /* NAV CHAPTERS */
  .chapter-nav { display: flex; overflow-x: auto; background: white; border-bottom: 2px solid var(--border); padding: 0 8px; gap: 4px; scrollbar-width: none; }
  .chapter-nav::-webkit-scrollbar { display: none; }
  .chapter-nav button { flex-shrink: 0; padding: 10px 14px; border: none; background: none; font-family: inherit; font-size: 0.82rem; color: var(--muted); cursor: pointer; border-bottom: 3px solid transparent; white-space: nowrap; transition: all 0.2s; }
  .chapter-nav button.active { color: var(--brown); border-bottom-color: var(--gold); font-weight: bold; }
  .chapter-nav button:hover { color: var(--brown); }

  /* MAIN */
  main { padding: 12px 14px 80px; max-width: 680px; margin: 0 auto; }

  /* CHAPTER HEADER */
  .chapter-header { text-align: center; padding: 18px 0 10px; }
  .chapter-header h2 { font-size: 1.1rem; color: var(--brown); letter-spacing: 0.05em; text-transform: uppercase; }
  .chapter-header p { font-size: 0.82rem; color: var(--muted); font-style: italic; margin-top: 4px; }

  /* RECIPE CARD */
  .recipe-card { background: var(--card); border: 1px solid var(--border); border-radius: 14px; margin-bottom: 14px; overflow: hidden; box-shadow: var(--shadow); }
  .recipe-card-header { padding: 14px 16px; cursor: pointer; display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; }
  .recipe-card-header:active { background: var(--gold-light); }
  .recipe-num { font-size: 0.72rem; color: var(--gold); text-transform: uppercase; letter-spacing: 0.08em; font-style: normal; display: block; margin-bottom: 2px; }
  .recipe-title { font-size: 1.02rem; color: var(--brown); font-weight: bold; line-height: 1.3; }
  .recipe-subtitle { font-size: 0.8rem; color: var(--muted); margin-top: 3px; font-style: italic; }
  .recipe-tags { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 7px; }
  .tag { background: var(--gold-light); color: var(--brown); font-size: 0.7rem; padding: 2px 8px; border-radius: 10px; border: 1px solid var(--border); }
  .tag.tm { background: #e8f0e8; color: var(--green); border-color: #c5d9c5; }
  .chevron { font-size: 1.1rem; color: var(--gold); flex-shrink: 0; transition: transform 0.25s; margin-top: 4px; }
  .recipe-card.open .chevron { transform: rotate(180deg); }

  /* RECIPE BODY */
  .recipe-body { display: none; border-top: 1px solid var(--border); }
  .recipe-card.open .recipe-body { display: block; }

  /* TABS (TM / Garnek) */
  .method-tabs { display: flex; border-bottom: 1px solid var(--border); }
  .method-tab { flex: 1; padding: 9px 6px; text-align: center; font-size: 0.82rem; cursor: pointer; border: none; background: none; font-family: inherit; color: var(--muted); border-bottom: 2px solid transparent; }
  .method-tab.active { color: var(--green); border-bottom-color: var(--green); font-weight: bold; }

  /* CONTENT SECTIONS */
  .recipe-section { padding: 14px 16px; }
  .recipe-section + .recipe-section { border-top: 1px dashed var(--border); }
  .section-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gold); font-weight: bold; margin-bottom: 8px; }

  /* INGREDIENTS */
  .ingredient-list { list-style: none; }
  .ingredient-list li { padding: 5px 0; font-size: 0.92rem; display: flex; align-items: flex-start; gap: 8px; border-bottom: 1px dotted #e8d5b0; }
  .ingredient-list li:last-child { border-bottom: none; }
  .ingredient-list li::before { content: "●"; color: var(--gold); font-size: 0.6rem; margin-top: 5px; flex-shrink: 0; }

  /* STEPS */
  .step-list { list-style: none; counter-reset: steps; }
  .step-list li { counter-increment: steps; padding: 8px 0 8px 36px; font-size: 0.92rem; position: relative; border-bottom: 1px dotted #e8d5b0; }
  .step-list li:last-child { border-bottom: none; }
  .step-list li::before { content: counter(steps); position: absolute; left: 0; top: 6px; background: var(--gold); color: white; width: 24px; height: 24px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: bold; font-style: normal; }

  /* TIPS */
  .tip-box { background: #fff8e8; border-left: 3px solid var(--gold); padding: 10px 13px; border-radius: 0 8px 8px 0; font-size: 0.87rem; color: var(--text); margin-top: 6px; }
  .tip-box strong { color: var(--brown); }

  /* PROPERTIES */
  .prop-list { list-style: none; }
  .prop-list li { padding: 4px 0; font-size: 0.87rem; display: flex; gap: 8px; }
  .prop-list li::before { content: "🌿"; font-size: 0.8rem; flex-shrink: 0; }

  /* WARNING */
  .warning-box { background: #fff0e8; border-left: 3px solid #d4763a; padding: 10px 13px; border-radius: 0 8px 8px 0; font-size: 0.87rem; margin-top: 6px; }

  /* PROTOCOL PAGE */
  .protocol-box { background: var(--card); border: 1px solid var(--border); border-radius: 14px; padding: 18px; margin-bottom: 14px; box-shadow: var(--shadow); }
  .protocol-box h3 { color: var(--brown); font-size: 1rem; margin-bottom: 10px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
  .protocol-box p, .protocol-box li { font-size: 0.9rem; line-height: 1.65; }
  .protocol-box ul { padding-left: 18px; margin-top: 8px; }
  .protocol-box li { margin-bottom: 4px; }
  .phase-badge { display: inline-block; background: var(--gold); color: white; font-size: 0.72rem; padding: 2px 10px; border-radius: 10px; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.08em; }

  /* DEKALOG */
  .rule-item { display: flex; gap: 12px; align-items: flex-start; padding: 10px 0; border-bottom: 1px dotted var(--border); }
  .rule-num { background: var(--brown); color: white; width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.75rem; flex-shrink: 0; font-weight: bold; }
  .rule-text { font-size: 0.9rem; }
  .rule-text strong { color: var(--brown); }

  /* SPICE TABLE */
  .spice-table { width: 100%; border-collapse: collapse; font-size: 0.83rem; }
  .spice-table th { background: var(--brown); color: white; padding: 8px 10px; text-align: left; font-weight: normal; }
  .spice-table td { padding: 8px 10px; border-bottom: 1px solid var(--border); vertical-align: top; }
  .spice-table tr:nth-child(even) td { background: var(--gold-light); }

  /* SHOPPING LIST */
  .shop-category { margin-bottom: 14px; }
  .shop-category h4 { color: var(--brown); font-size: 0.88rem; text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 8px; padding-bottom: 4px; border-bottom: 1px solid var(--border); }
  .shop-item { display: flex; align-items: center; gap: 10px; padding: 6px 0; font-size: 0.88rem; border-bottom: 1px dotted #e8d5b0; }
  .shop-item:last-child { border-bottom: none; }
  .shop-check { width: 20px; height: 20px; border: 2px solid var(--border); border-radius: 4px; flex-shrink: 0; cursor: pointer; display: flex; align-items: center; justify-content: center; background: white; transition: all 0.15s; }
  .shop-check.checked { background: var(--green); border-color: var(--green); color: white; }

  /* HIDDEN */
  .page { display: none; }
  .page.active { display: block; }
  .recipe-card.hidden { display: none; }

  /* BOTTOM NAV */
  .bottom-nav { position: fixed; bottom: 0; left: 0; right: 0; background: white; border-top: 1px solid var(--border); display: flex; padding: 6px 0 max(6px, env(safe-area-inset-bottom)); z-index: 200; }
  .bottom-nav button { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 3px; border: none; background: none; color: var(--muted); font-size: 0.65rem; padding: 4px 2px; cursor: pointer; font-family: inherit; transition: color 0.2s; }

  /* FAZY */
  .phase-card { background: var(--card); border: 1px solid var(--border); border-radius: 14px; margin-bottom: 14px; overflow: hidden; box-shadow: var(--shadow); }
  .phase-card-header { padding: 14px 16px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
  .phase-card-header:active { background: var(--gold-light); }
  .phase-card-body { display: none; border-top: 1px solid var(--border); padding: 14px 16px; }
  .phase-card.open .phase-card-body { display: block; }
  .phase-card.open .chevron { transform: rotate(180deg); }
  .phase-title { font-size: 1rem; color: var(--brown); font-weight: bold; }
  .phase-desc { font-size: 0.8rem; color: var(--muted); font-style: italic; margin-top: 3px; }
  .phase-goal { background: var(--gold-light); border-left: 3px solid var(--gold); padding: 8px 12px; border-radius: 0 8px 8px 0; font-size: 0.85rem; margin-bottom: 14px; }
  .phase-goal strong { color: var(--brown); }
  .food-group { margin-bottom: 14px; }
  .food-group-title { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--gold); font-weight: bold; margin-bottom: 7px; display: flex; align-items: center; gap: 6px; }
  .food-list { list-style: none; }
  .food-list li { padding: 5px 0 5px 20px; font-size: 0.88rem; position: relative; border-bottom: 1px dotted var(--border); }
  .food-list li:last-child { border-bottom: none; }
  .food-list li::before { content: "●"; color: var(--gold); font-size: 0.55rem; position: absolute; left: 4px; top: 8px; }
  .food-list li em { color: var(--muted); font-size: 0.82rem; }
  .post-table { width: 100%; border-collapse: collapse; font-size: 0.83rem; margin-top: 8px; }
  .post-table th { background: var(--brown); color: white; padding: 8px 10px; text-align: left; font-weight: normal; font-size: 0.8rem; }
  .post-table td { padding: 8px 10px; border-bottom: 1px solid var(--border); vertical-align: top; line-height: 1.5; }
  .post-table tr:nth-child(even) td { background: var(--gold-light); }
  .golden-rule { background: #fff0e8; border: 1px solid #d4763a; border-radius: 10px; padding: 12px 14px; font-size: 0.87rem; margin-top: 12px; }
  .golden-rule strong { color: #a0501a; display: block; margin-bottom: 4px; }
  .bottom-nav button.active { color: var(--brown); }
  .bottom-nav button span.icon { font-size: 1.3rem; }
</style>
</head>
<body>

<header>
  <h1>Kuchnia Ajurwedyjska & TMC</h1>
  <p>22 przepisy · Thermomix & tradycyjne</p>
</header>

<!-- PAGE: RECIPES -->
<div class="page active" id="page-recipes">
  <div class="search-bar">
    <input type="search" id="search-input" placeholder="🔍 Szukaj przepisu..." oninput="filterRecipes()">
  </div>
  <nav class="chapter-nav" id="chapter-nav">
    <button class="active" onclick="filterChapter('all', this)">Wszystkie</button>
    <button onclick="filterChapter('congee', this)">I. Congee</button>
    <button onclick="filterChapter('kasze', this)">II. Kasze</button>
    <button onclick="filterChapter('ryz', this)">III. Ryż</button>
    <button onclick="filterChapter('zupy', this)">IV. Zupy</button>
    <button onclick="filterChapter('warzywa', this)">V. Warzywa</button>
    <button onclick="filterChapter('napoje', this)">VI. Napoje</button>
    <button onclick="filterChapter('desery', this)">VII. Desery</button>
    <button onclick="filterChapter('bazy', this)">VIII. Bazy</button>
  </nav>
  <main id="recipe-list">
    <!-- Recipes injected by JS -->
  </main>
</div>

<!-- PAGE: PROTOCOL -->
<div class="page" id="page-protocol">
  <main>
    <div class="chapter-header">
      <h2>Protokół 3-dniowego Postu</h2>
      <p>Reset trawienia według Ajurwedy i TMC</p>
    </div>

    <div class="protocol-box">
      <span class="phase-badge">Faza 1 · Dni -3 do -1 · Wejście</span>
      <h3>Przygotowanie do Postu</h3>
      <p>Stopniowe odstawianie ciężkostrawnych produktów. Cel: wygasić stany zapalne i przygotować jelita.</p>
      <ul>
        <li>Odstaw mięso, nabiał, cukier, alkohol, gluten</li>
        <li>Jedz kasze (jaglana, quinoa), warzywa gotowane, ryż basmati</li>
        <li>Pij ciepłą wodę przez cały dzień (małymi łykami)</li>
        <li>Dodaj Złote Mleko na wieczór</li>
        <li>Ostatni dzień: tylko kleik ryżowy i gotowane warzywa</li>
      </ul>
    </div>

    <div class="protocol-box">
      <span class="phase-badge">Faza 2 · Dni 1–3 · Post</span>
      <h3>Post Congee</h3>
      <p>Podstawa: Ratunkowe Congee (Przepis 1). Jeden składnik, maksymalny efekt.</p>
      <ul>
        <li><strong>Dzień 1–2:</strong> Tylko Congee z imbirem, koprem i skórką pomarańczy. 3–4 porcje dziennie.</li>
        <li><strong>Dzień 3:</strong> Jeśli brak gazów → Congee z fasolką mung (Przepis 2)</li>
        <li>Pij Herbatę Trawienia (Przepis 17) między posiłkami</li>
        <li>Pij Złotą Wodę (Przepis 16) rano na czczo</li>
        <li>Absolutnie bez surowych warzyw, owoców, nabiału, mięsa</li>
        <li>Minimum 2 litry ciepłej wody dziennie</li>
      </ul>
      <div class="tip-box"><strong>Obserwacja:</strong> Jeśli po Congee z mung poczujesz twardy brzuch lub gazy – wróć do czystego Congee na kolejny posiłek.</div>
    </div>

    <div class="protocol-box">
      <span class="phase-badge">Faza 3 · Dni 4–7 · Wyjście</span>
      <h3>Stopniowe Wyjście</h3>
      <p>Równie ważne co sam post. Nie wolno „skoczyć" od razu na normalne jedzenie.</p>
      <ul>
        <li><strong>Dzień 4:</strong> Congee + Jaglanka z jabłkiem (Przepis 3)</li>
        <li><strong>Dzień 5:</strong> + Ryż basmati (Przepis 7 lub 8) + Zupa dyniowa (Przepis 10)</li>
        <li><strong>Dzień 6:</strong> + Kasza jaglana z quinoą (Przepis 4 lub 5) + Krem z buraka (Przepis 11)</li>
        <li><strong>Dzień 7:</strong> + Pieczone warzywa (Przepis 13) + Złote Mleko (Przepis 15)</li>
        <li>Wracaj do produktów po jednym na raz – obserwuj reakcje</li>
      </ul>
    </div>

    <div class="protocol-box">
      <h3>⚡ Zasady podczas całego protokołu</h3>
      <ul>
        <li>Nigdy zimne posiłki ani napoje</li>
        <li>Nigdy mikrofalówka – tylko garnek lub Thermomix</li>
        <li>Jedz powoli, żuj 20–30 razy każdy kęs</li>
        <li>Ostatni posiłek max. o 19:00</li>
        <li>Odpoczynek i ciepło – to jest czas na regenerację</li>
      </ul>
    </div>
  </main>
</div>

<!-- PAGE: DEKALOG -->
<div class="page" id="page-dekalog">
  <main>
    <div class="chapter-header">
      <h2>Dekalog Zdrowego Jedzenia</h2>
      <p>13 zasad Ajurwedy i TMC</p>
    </div>

    <div class="protocol-box">
      <div class="rule-item"><div class="rule-num">1</div><div class="rule-text"><strong>ZAWSZE NA CIEPŁO.</strong> Zimne posiłki i napoje osłabiają „ogień trawienny" (Agni) i tworzą śluz.</div></div>
      <div class="rule-item"><div class="rule-num">2</div><div class="rule-text"><strong>BEZ MIKROFALÓWKI.</strong> Zawsze podgrzewaj w garnku na małym ogniu z odrobiną wody.</div></div>
      <div class="rule-item"><div class="rule-num">3</div><div class="rule-text"><strong>ŻUCIE.</strong> Każdy kęs żuj co najmniej 20–30 razy. Trawienie zaczyna się w ustach.</div></div>
      <div class="rule-item"><div class="rule-num">4</div><div class="rule-text"><strong>GHEE &gt; OLEJ.</strong> Masło klarowane najlepiej wspiera trawienie i jest nośnikiem dla przypraw.</div></div>
      <div class="rule-item"><div class="rule-num">5</div><div class="rule-text"><strong>CIEPŁA WODA.</strong> Pij małymi łykami przez cały dzień. Zimna woda „gasi piec".</div></div>
      <div class="rule-item"><div class="rule-num">6</div><div class="rule-text"><strong>IMBIR, KUMIN, KOPER.</strong> Twoja codzienna apteczka. Dodaj do każdego dania.</div></div>
      <div class="rule-item"><div class="rule-num">7</div><div class="rule-text"><strong>OSTATNI POSIŁEK DO 19:00.</strong> Trawienie wieczorem jest najsłabsze – daj ciału czas na odpoczynek.</div></div>
      <div class="rule-item"><div class="rule-num">8</div><div class="rule-text"><strong>MIÓD NIGDY DO GORĄCYCH NAPOJÓW.</strong> Podgrzany miód tworzy „Amę" (toksyny). Dodawaj tylko gdy przestanie parzyć.</div></div>
      <div class="rule-item"><div class="rule-num">9</div><div class="rule-text"><strong>PŁUCZ KASZE I RYŻ.</strong> Usuwasz goryczkę (jaglanka) i nadmiar skrobi (ryż), która fermentuje w jelitach.</div></div>
      <div class="rule-item"><div class="rule-num">10</div><div class="rule-text"><strong>ODPOCZYNEK PO POSIŁKU.</strong> 10–15 minut spokoju. Nie od razu bieganie ani praca.</div></div>
      <div class="rule-item"><div class="rule-num">11</div><div class="rule-text"><strong>BROKUŁ TYLKO ZMIKSOWANY.</strong> Całe różyczki produkują gazy. W formie zupy-krem – bezpieczne.</div></div>
      <div class="rule-item"><div class="rule-num">12</div><div class="rule-text"><strong>ŚWIEŻY IMBIR DO ODGRZEWANIA.</strong> „Naprawia" zmęczenie przechowywanego jedzenia i pobudza Qi.</div></div>
      <div class="rule-item" style="border-bottom:none"><div class="rule-num">13</div><div class="rule-text"><strong>OBSERWUJ SWÓJ BRZUCH.</strong> Każde ciało jest inne. Jeśli coś powoduje gazy – usuń to i wróć za tydzień.</div></div>
    </div>

    <div class="chapter-header" style="margin-top:10px">
      <h2>Apteczka Przyprawowa</h2>
    </div>
    <div class="protocol-box" style="padding:0; overflow:hidden">
      <table class="spice-table">
        <tr><th>Przyprawa</th><th>Działanie</th><th>Gdzie stosować</th></tr>
        <tr><td><strong>Imbir</strong></td><td>Rozpala Agni, rusza zastoje, odkażający</td><td>Wszędzie – Congee, kasze, zupy, herbata</td></tr>
        <tr><td><strong>Kumin</strong></td><td>Neutralizuje gazy, wspomaga trawienie</td><td>Kasze, zupy, ryż, strączki</td></tr>
        <tr><td><strong>Koper włoski</strong></td><td>Pogromca wzdęć, przepycha zalegające jedzenie</td><td>Herbata trawienia, Congee</td></tr>
        <tr><td><strong>Kardamon</strong></td><td>Usuwa mgłę mózgową, rozprasza śluz</td><td>Kakao, jaglanka, mleko, napoje</td></tr>
        <tr><td><strong>Kurkuma</strong></td><td>Przeciwzapalna, oczyszcza krew, wspiera wątrobę</td><td>Złote Mleko, zupy, ryż</td></tr>
        <tr><td><strong>Cynamon</strong></td><td>Reguluje krążenie energii, stabilizuje cukier</td><td>Jaglanka, pieczone jabłka, kakao</td></tr>
        <tr><td><strong>Asafetyda (hing)</strong></td><td>Legendarnie na gazy i fermentację</td><td>Oliwa, zupy, strączki</td></tr>
        <tr><td><strong>Czarny pieprz</strong></td><td>Aktywuje kurkumę (piperyna), rozgrzewa</td><td>Złote Mleko, Złota Woda</td></tr>
      </table>
    </div>

    <div class="chapter-header" style="margin-top:10px">
      <h2>Lista Zakupów</h2>
    </div>
    <div class="protocol-box">
      <div class="shop-category">
        <h4>Zboża i kasze</h4>
        <div class="shop-item"><div class="shop-check" onclick="toggleCheck(this)"></div>Kasza jaglana</div>
        <div class="shop-item"><div class="shop-check" onclick="toggleCheck(this)"></div>Quinoa (biała)</div>
        <div class="shop-item"><div class="shop-check" onclick="toggleCheck(this)"></div>Ryż biały (okrągły / jaśminowy)</div>
        <div class="shop-item"><div class="shop-check" onclick="toggleCheck(this)"></div>Ryż basmati</div>
        <div class="shop-item"><div class="shop-check" onclick="toggleCheck(this)"></div>Płatki owsiane (górskie)</div>
        <div class="shop-item"><div class="shop-check" onclick="toggleCheck(this)"></div>Fasolka mung (żółta łuskana)</div>
      </div>
